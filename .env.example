# tastytrade-cli — environment configuration
# Copy to .env and fill in values. Never commit .env.
# Credentials (client_secret, refresh_token) are stored in the OS keychain via 'tt login'.

# ── Required ─────────────────────────────────────────────────────────────────

TASTYTRADE_CLIENT_ID=your_client_id
TASTYTRADE_ACCOUNT_ID=5WXxxxxx

# Target environment. Default: sandbox (cert).
# Sandbox uses the tastyworks.com domain — note: NOT tastytrade.com.
TASTYTRADE_BASE_URL=https://api.cert.tastyworks.com

# User-Agent is REQUIRED by the API. Missing/malformed returns 401 from nginx.
# Format: <product>/<version>
TASTYTRADE_USER_AGENT=tastytrade-cli/1.0.0

# ── Optional ──────────────────────────────────────────────────────────────────

# Accept-Version: sent on versioned endpoints. Omit to use latest version.
# Format: YYYYMMDD
TASTYTRADE_API_VERSION=

# ── Rate Limits (requests per second per family) ──────────────────────────────
# Community-observed conservative defaults. tastytrade does not publish limits.
# Always honour the Retry-After header on 429 responses — it overrides these.

TASTYTRADE_RATE_DEFAULT_RPS=2
TASTYTRADE_RATE_ORDERS_RPS=1       # HARD CAP — never raise above 1
TASTYTRADE_RATE_READ_RPS=2
TASTYTRADE_RATE_INSTRUMENTS_RPS=2
TASTYTRADE_RATE_MARKETDATA_RPS=2
TASTYTRADE_RATE_TRANSACTIONS_RPS=1

# ── Safety Controls ────────────────────────────────────────────────────────────

# LIVE_TRADING: MUST be 'true' AND TASTYTRADE_BASE_URL must point to production.
# Both conditions must hold — cert URL with LIVE_TRADING=true is blocked.
TASTYTRADE_LIVE_TRADING=false

# KILL_SWITCH: Set to 'true' to halt ALL order submission immediately.
# Equivalent to: touch ~/.config/tastytrade-cli/KILL
# Also: 'tt kill' and 'tt resume' toggle the file-based kill switch.
TASTYTRADE_KILL_SWITCH=false

# Circuit breaker limits
TASTYTRADE_MAX_ORDERS_PER_HOUR=10
TASTYTRADE_MAX_ORDERS_PER_DAY=20

# NLQ guard
TASTYTRADE_NLQ_FLOOR_ABSOLUTE=5000    # halt new positions if NLQ drops below this ($)
TASTYTRADE_NLQ_MAX_DRAWDOWN_PCT=0.10  # halt if intraday drawdown exceeds 10%

# ── Monitoring ─────────────────────────────────────────────────────────────────

# Prometheus metrics endpoint — bind to localhost only.
TASTYTRADE_METRICS_ADDR=127.0.0.1:9090

# Alert webhook (Telegram bot API or other HTTP endpoint)
TASTYTRADE_ALERT_WEBHOOK_URL=
